{
  "name": "@cyoda/workflow-react",
  "version": "0.0.0",
  "description": "React-based editor shell for Cyoda workflows.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@cyoda/workflow-core": "workspace:*",
    "@cyoda/workflow-graph": "workspace:*",
    "@cyoda/workflow-layout": "workspace:*",
    "@cyoda/workflow-viewer": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18",
    "react-dom": "^18",
    "reactflow": "^11"
  },
  "devDependencies": {
    "@testing-library/react": "^14.2.0",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "jsdom": "^24.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "reactflow": "^11.11.4"
  }
}
